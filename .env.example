# Copy this file to `.env` on your VPS, then `docker compose up -d`.

# --- Required ---

# Domain pointed at this VPS (A record). Caddy will auto-provision TLS for it.
DOMAIN=runner.example.com

# Shared secret. Generate with `openssl rand -hex 32`.
# Vercel needs the same value as WEBWRIGHT_RUNNER_TOKEN.
RUNNER_TOKEN=

# Postgres password. Generate with `openssl rand -hex 24`.
POSTGRES_PASSWORD=

# --- Optional ---

POSTGRES_DB=dealmatch
POSTGRES_USER=dealmatch
POSTGRES_PORT=5432

# Enables LLM extraction inside the runner. Without it, the runner falls back
# to a JSON-LD-only heuristic.
ANTHROPIC_API_KEY=
