# --- Required for full functionality ---

# Postgres on your VPS. Add `?sslmode=require` if your Postgres is TLS-only.
DATABASE_URL=postgres://dealmatch:PASSWORD@runner.example.com:5432/dealmatch

# Webwright/Playwright runner on your VPS. Caddy in front terminates TLS.
WEBWRIGHT_RUNNER_URL=https://runner.example.com/run
WEBWRIGHT_RUNNER_TOKEN=

# --- Optional ---

# Enables LLM verdict synthesis. Without it, a rule-based fallback is used.
AI_GATEWAY_API_KEY=
